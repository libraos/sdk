{
  "name": "@libraos/client",
  "version": "0.1.0-alpha.0",
  "description": "Framework-agnostic TypeScript client kit for LibraOS — typed REST client (generated from the partner OpenAPI spec), OIDC Auth-Code+PKCE+refresh helper, and AG-UI streaming event types. No React/framework dependencies; runs in browsers, Node 22, and React Native.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "codegen": "openapi-typescript ../../openapi/nova-os-partner.v1.yaml -o src/_generated/schema.d.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/libraos/sdk",
    "directory": "clients/typescript"
  }
}
