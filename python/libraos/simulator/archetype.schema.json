{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NovaOSSimulatorArchetype",
  "type": "object",
  "required": ["name", "description", "hidden_facts", "disclosure_willingness", "success_signal"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "hidden_facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "disclosure_willingness": {
      "type": "string",
      "enum": ["open", "cautious", "guarded"]
    },
    "success_signal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "language_register": {
      "type": "string",
      "maxLength": 200
    },
    "demographic": {
      "type": "object",
      "additionalProperties": true
    },
    "failure_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "termination_conditions": {
      "type": "object",
      "properties": {
        "max_turns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "success_signal_in_target_response": {
          "type": "boolean"
        },
        "failure_signal_match": {
          "type": "string",
          "enum": ["any", "all"]
        }
      },
      "additionalProperties": false
    },
    "model_override": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+/[A-Za-z0-9._-]+$"
    }
  },
  "additionalProperties": false
}
